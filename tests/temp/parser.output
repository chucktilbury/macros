Terminals unused in grammar

    RAW_TEXT


Grammar

    0 $accept: module $end

    1 module: module_item
    2       | module module_item

    3 module_item: define_clause
    4            | if_clause
    5            | reference

    6 $@1: ε

    7 module_item: INCLUDE $@1 QSTRG

    8 $@2: ε

    9 module_item: ERROR $@2 QSTRG

   10 $@3: ε

   11 module_item: MESSAGE $@3 QSTRG

   12 reference: REFERENCE ref_parm

   13 ref_parm_list_item: NAME
   14                   | reference
   15                   | QSTRG
   16                   | NUMBER

   17 ref_parm_list: ref_parm_list_item
   18              | ref_parm_list ',' ref_parm_list_item

   19 ref_parm: ε
   20         | '(' ')'
   21         | '(' ref_parm_list ')'

   22 define: DEFINE

   23 define_clause: define NAME
   24              | define NAME BLOCK
   25              | define NAME '(' def_parm_list ')' BLOCK

   26 def_parm_list: NAME
   27              | def_parm_list ',' NAME

   28 $@4: ε

   29 if_clause: IF $@4 '(' expression ')' BLOCK else_clause

   30 else: ELSE

   31 else_clause_item: else '(' expression ')' BLOCK

   32 else_clause_item_list: else_clause_item
   33                      | else_clause_item_list else_clause_item

   34 final_else_clause: else '(' ')' BLOCK
   35                  | else BLOCK

   36 else_clause: else_clause_item_list
   37            | else_clause_item_list final_else_clause
   38            | final_else_clause

   39 expression: reference
   40           | NUMBER
   41           | NAME
   42           | expression EQU expression
   43           | expression NEQU expression
   44           | expression LT expression
   45           | expression GT expression
   46           | expression LTE expression
   47           | expression GTE expression
   48           | expression AND expression
   49           | expression OR expression
   50           | NOT expression
   51           | '(' expression ')'


